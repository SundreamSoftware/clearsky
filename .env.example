# GIOŚ API base URL — use /api so requests are proxied by Vite (dev) and Nginx (prod)
# This avoids CORS: browser → same-origin /api/* → proxy → api.gios.gov.pl
VITE_GIOS_API_BASE_URL=/api

# WAQI (World Air Quality Index) token — required for global air quality stations
# Get a free token at https://aqicn.org/data-platform/token/
# The token is injected server-side (Vite proxy in dev, Nginx in prod) — never exposed to the browser
VITE_WAQI_TOKEN=
